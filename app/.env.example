# PostgreSQL connection. Local dev default (db/docker-compose.yml):
DATABASE_URL=postgres://postgres:vr@localhost:5433/voteright
# Hosted Postgres (e.g. Neon): use the pooled connection string and keep sslmode=require:
# DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# Admin-console auth (production): TOTP + signed sessions. Generate both with
#   node scripts/gen-admin-secret.mjs
# and enroll the printed otpauth:// URI in an authenticator app. Production
# fails closed if these are unset.
# ADMIN_TOTP_SECRET=
# ADMIN_SESSION_SECRET=

# Local-dev fallback only (used when ADMIN_TOTP_SECRET is unset and
# NODE_ENV != production): the value doubles as the sign-in code.
ADMIN_TOKEN=dev-admin
